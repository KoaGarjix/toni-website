---
const { title = 'Toni Vähäkuopus' } = Astro.props;

const pageTitle = title === 'Toni Vähäkuopus'
	? title
	: `${title} | Toni Vähäkuopus`;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
	</head>
	<body>
		<header class="site-header">
			<div class="site-shell header-inner">
				<a class="site-name" href="/">Toni Vähäkuopus</a>

				<nav class="site-nav" aria-label="Primary navigation">
					<a href="/">Home</a>
					<a href="/about">About</a>
					<a href="/projects">Projects</a>
					<a href="/lab">Lab</a>
					<a href="/contact">Contact</a>
				</nav>
			</div>
		</header>

		<main class="site-shell site-main">
			<slot />
		</main>

		<footer class="site-footer">
			<div class="site-shell">
				<p>&copy; {new Date().getFullYear()} Toni Vähäkuopus</p>
			</div>
		</footer>
	</body>
</html>

<style>
	:global(*) {
		box-sizing: border-box;
	}

	:global(body) {
		margin: 0;
		color: #222;
		background: #fff;
		font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
		line-height: 1.6;
	}

	:global(a) {
		color: inherit;
	}

	.site-shell {
		width: min(100% - 2rem, 860px);
		margin: 0 auto;
	}

	.site-header {
		border-bottom: 1px solid #e5e5e5;
	}

	.header-inner {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		align-items: center;
		justify-content: space-between;
		padding: 1rem 0;
	}

	.site-name {
		font-weight: 700;
		text-decoration: none;
	}

	.site-nav {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
	}

	.site-nav a {
		text-decoration: none;
	}

	.site-nav a:hover,
	.site-nav a:focus {
		text-decoration: underline;
	}

	.site-main {
		padding: 3rem 0;
	}

	:global(section + section) {
		margin-top: 3rem;
		padding-top: 2rem;
		border-top: 1px solid #e5e5e5;
	}

	:global(h1),
	:global(h2),
	:global(h3),
	:global(p) {
		margin-top: 0;
	}

	:global(h1) {
		margin-bottom: 1rem;
		font-size: 2rem;
		line-height: 1.2;
	}

	:global(h2) {
		margin-bottom: 0.75rem;
		font-size: 1.35rem;
		line-height: 1.3;
	}

	:global(h3) {
		margin-bottom: 0.25rem;
		font-size: 1rem;
	}

	:global(.preview-list) {
		display: grid;
		gap: 1rem;
		margin: 1.5rem 0 0;
		padding: 0;
		list-style: none;
	}

	:global(.preview-list li) {
		padding: 1rem 0;
		border-top: 1px solid #e5e5e5;
	}

	:global(.content-list) {
		display: grid;
		gap: 1rem;
		margin: 2rem 0 0;
		padding: 0;
		list-style: none;
	}

	:global(.content-list > li) {
		margin: 0;
	}

	:global(.entry-card) {
		display: block;
		padding: 1.25rem;
		border: 1px solid #ddd;
		border-radius: 6px;
		text-decoration: none;
		transition:
			border-color 120ms ease,
			background-color 120ms ease;
	}

	:global(.entry-card:hover),
	:global(.entry-card:focus) {
		border-color: #999;
		background: #fafafa;
	}

	:global(.entry-card:focus) {
		outline: 2px solid #444;
		outline-offset: 3px;
	}

	:global(.entry-card h2) {
		margin-bottom: 0.5rem;
	}

	:global(.entry-card:hover h2),
	:global(.entry-card:focus h2) {
		text-decoration: underline;
	}

	:global(.entry-description) {
		max-width: 680px;
		color: #444;
	}

	:global(.entry-meta) {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem 1rem;
		margin-bottom: 1rem;
		color: #666;
		font-size: 0.95rem;
	}

	:global(.entry-status) {
		text-transform: capitalize;
	}

	:global(.tag-list) {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	:global(.tag-list li) {
		padding: 0.15rem 0.5rem;
		border: 1px solid #ddd;
		border-radius: 999px;
		color: #555;
		font-size: 0.85rem;
	}

	:global(.entry-link) {
		margin: 1rem 0 0;
		color: #444;
		font-size: 0.95rem;
		font-weight: 600;
	}

	:global(.entry-page) {
		max-width: 760px;
	}

	:global(.entry-header) {
		margin-bottom: 2.5rem;
		padding-bottom: 1.5rem;
		border-bottom: 1px solid #e5e5e5;
	}

	:global(.back-link) {
		color: #555;
		font-size: 0.95rem;
	}

	:global(.entry-content) {
		max-width: 680px;
	}

	:global(.entry-content p) {
		margin-bottom: 1.25rem;
	}

	:global(.entry-content p:last-child) {
		margin-bottom: 0;
	}

	.site-footer {
		border-top: 1px solid #e5e5e5;
		color: #666;
		font-size: 0.9rem;
	}

	.site-footer p {
		margin: 0;
		padding: 1.5rem 0;
	}
</style>
