---
const { title = 'Karjix' } = Astro.props;

const pageTitle = title === 'Karjix'
	? title
	: `${title} | Karjix`;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
	</head>
	<body>
		<header class="site-header">
			<div class="site-shell header-inner">
				<a class="site-name" href="/">Karjix - Break it untill it works.</a>

				<nav class="site-nav" aria-label="Primary navigation">
					<a href="/">Home</a>
					<a href="/about">About</a>
					<a href="/projects">Projects</a>
					<a href="/lab">Lab</a>
					<a href="/contact">Contact</a>
				</nav>
			</div>
		</header>

		<main class="site-shell site-main">
			<slot />
		</main>

		<footer class="site-footer">
			<div class="site-shell">
				<p>&copy; {new Date().getFullYear()} Karjix</p>
			</div>
		</footer>
	</body>
</html>

<style>
	:global(*) {
		box-sizing: border-box;
	}

	:global(body) {
		margin: 0;
		color: #e5e7eb;
		background:
			radial-gradient(circle at 20% 20%, rgba(80, 144, 248, 0.08), transparent),
			linear-gradient(to bottom right, #1d2c4e, #222f4d, #31425e);
		font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
		line-height: 1.7;
	}

	:global(a) {
		color: #d8dee9;
		text-underline-offset: 0.18em;
		transition:
			color 120ms ease,
			text-decoration-color 120ms ease;
	}

	:global(a:hover),
	:global(a:focus) {
		color: #f8fafc;
		text-decoration-color: #94a3b8;
	}

	.site-shell {
		width: min(100% - 2rem, 880px);
		margin: 0 auto;
	}

	.site-header {
		border-bottom: 1px solid rgba(255, 255, 255, 0.05);
		background: rgba(15, 23, 42, 0.72);
	}

	.header-inner {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		align-items: center;
		justify-content: space-between;
		padding: 1rem 0;
	}

	.site-name {
		font-weight: 700;
		text-decoration: none;
	}

	.site-nav {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
	}

	.site-nav a {
		text-decoration: none;
	}

	.site-nav a:hover,
	.site-nav a:focus {
		text-decoration: underline;
		text-decoration-thickness: 1px;
	}

	.site-main {
		padding: 3.5rem 0 4rem;
	}

	:global(section + section) {
		margin-top: 3.75rem;
		padding-top: 2.75rem;
		border-top: 1px solid rgba(148, 163, 184, 0.18);
	}

	:global(h1),
	:global(h2),
	:global(h3),
	:global(p) {
		margin-top: 0;
	}

	:global(h1) {
		margin-bottom: 1.1rem;
		font-size: 2rem;
		line-height: 1.2;
	}

	:global(h2) {
		margin-bottom: 0.85rem;
		font-size: 1.35rem;
		line-height: 1.3;
	}

	:global(h3) {
		margin-bottom: 0.25rem;
		font-size: 1rem;
	}

	:global(p),
	:global(ul),
	:global(ol) {
		max-width: 700px;
	}

	:global(p) {
		margin-bottom: 1rem;
	}

	:global(p:last-child) {
		margin-bottom: 0;
	}

	:global(.preview-list) {
		display: grid;
		gap: 1.1rem;
		margin: 1.75rem 0 0;
		padding: 0;
		list-style: none;
	}

	:global(.preview-list li) {
		padding: 1.1rem 0;
		border-top: 1px solid rgba(148, 163, 184, 0.18);
	}

	:global(.content-list) {
		display: grid;
		gap: 1.15rem;
		margin: 2.25rem 0 0;
		padding: 0;
		list-style: none;
	}

	:global(.content-list > li) {
		margin: 0;
	}

	:global(.entry-card) {
		display: block;
		padding: 1.35rem;
		border: 1px solid rgba(148, 163, 184, 0.22);
		border-radius: 6px;
		background: rgba(15, 23, 42, 0.42);
		box-shadow: 0 1px 2px rgba(2, 6, 23, 0.18);
		text-decoration: none;
		transition:
			border-color 120ms ease,
			background-color 120ms ease,
			box-shadow 120ms ease,
			transform 120ms ease;
	}

	:global(.entry-card:hover),
	:global(.entry-card:focus) {
		border-color: rgba(203, 213, 225, 0.38);
		background: rgba(30, 41, 59, 0.58);
		box-shadow: 0 10px 24px rgba(2, 6, 23, 0.3);
		transform: translateY(-2px);
	}

	:global(.entry-card:focus) {
		outline: 2px solid rgba(203, 213, 225, 0.62);
		outline-offset: 3px;
	}

	:global(.entry-card h2) {
		margin-bottom: 0.5rem;
	}

	:global(.entry-card:hover h2),
	:global(.entry-card:focus h2) {
		text-decoration: underline;
	}

	:global(.entry-description) {
		max-width: 680px;
		color: #cbd5e1;
	}

	:global(.entry-meta) {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem 1rem;
		margin-bottom: 1rem;
		color: #aab6c7;
		font-size: 0.95rem;
	}

	:global(.entry-status) {
		text-transform: capitalize;
	}

	:global(.tag-list) {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	:global(.tag-list li) {
		padding: 0.15rem 0.5rem;
		border: 1px solid rgba(148, 163, 184, 0.24);
		border-radius: 999px;
		background: rgba(15, 23, 42, 0.36);
		color: #cbd5e1;
		font-size: 0.85rem;
	}

	:global(.entry-link) {
		margin: 1rem 0 0;
		color: #d8dee9;
		font-size: 0.95rem;
		font-weight: 600;
	}

	:global(.entry-page) {
		max-width: 760px;
	}

	:global(.entry-header) {
		margin-bottom: 2.75rem;
		padding-bottom: 1.75rem;
		border-bottom: 1px solid rgba(255,255,255,0.05);
	}

	:global(.back-link) {
		color: #cbd5e1;
		font-size: 0.95rem;
	}

	:global(.entry-content) {
		max-width: 680px;
	}

	:global(.entry-content p) {
		margin-bottom: 1.35rem;
	}

	:global(.entry-content p:last-child) {
		margin-bottom: 0;
	}

	.site-footer {
		border-top: 1px solid rgba(148, 163, 184, 0.18);
		color: #aab6c7;
		font-size: 0.9rem;
	}

	.site-footer p {
		margin: 0;
		padding: 1.5rem 0;
	}
</style>
